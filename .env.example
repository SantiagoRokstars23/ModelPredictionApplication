# Modelo Santiago -- variables de entorno de ejemplo (bootstrap oficial, BUILD-001)
# Copiar como .env y completar antes de ejecutar. Nunca versionar el .env real.

DATABASE_URL=postgresql+psycopg://modelo_santiago:modelo_santiago@localhost:5432/modelo_santiago
MODEL_VERSION=0.1.0

# Nota: el driver "psycopg" (v3) fue recomendado en docs/34-Decision-Oficial-del-Stack-Tecnologico.md,
# seccion 11, pero todavia NO esta declarado como dependencia en pyproject.toml -- el brief de
# BUILD-001 restringe la lista de dependencias exactamente a las once ya listadas (seccion 4),
# sin agregar librerias adicionales. Sin ese driver, esta cadena de conexion no podra usarse
# realmente todavia -- queda documentado aqui para la primera mision que conecte la base de datos.

POSTGRES_DB=modelo_santiago
POSTGRES_USER=modelo_santiago
POSTGRES_PASSWORD=modelo_santiago
